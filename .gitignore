/target
**/*.rs.bk
Cargo.lock.bak

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Test fixtures (generated)
/examples/**/.specify/
/examples/**/.specere/
/examples/**/specs/

# cargo-dist
/dist/

# <!-- specere:begin harness -->
# Claude Code local settings and session artifacts (credential-bearing)
.claude/settings.local.json
.claude/.session-*
.claude/scheduled_tasks.lock
# SpecERE runtime state (belief store, events, OTel dumps) — committed files
# are the explicit allowlist below.
.specere/*
!.specere/manifest.toml
!.specere/sensor-map.toml
!.specere/review-queue.md
!.specere/decisions.log
# <!-- specere:end harness -->

